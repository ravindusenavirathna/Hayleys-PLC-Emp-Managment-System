# --- Supabase ---
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Database (Prisma) ---
# Get from: https://supabase.com/dashboard/project/<your-project>/settings/database
# 1. DATABASE_URL: Uses Pooler in Transaction mode (port 6543) for runtime queries (includes pgbouncer and connection_limit overrides)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=15"

# 2. DIRECT_URL: Uses Pooler in Session mode (port 5432) for schema pushes / migrations (safest for IPv4 networks)
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:5432/postgres"

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Hayleys-PLC-Emp-Managment-System"
